#!/bin/bash

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
RED="\033[0;31m"
NC="\033[0m"

color_status() {
  case "$1" in
    none) echo -e "${GREEN}$2${NC}" ;;
    minor) echo -e "${YELLOW}$2${NC}" ;;
    major|critical) echo -e "${RED}$2${NC}" ;;
    *) echo "$2" ;;
  esac
}

format_http() {
  CODE=$1

  if [[ "$CODE" == "000" ]]; then
    echo "${CODE} (no response)"
  elif [[ "$CODE" =~ ^[23][0-9][0-9]$ ]]; then
    echo "${CODE} (normal)"
  else
    echo "${CODE} (abnormal)"
  fi
}

is_normal_http() {
  CODE=$1
  [[ "$CODE" =~ ^[23][0-9][0-9]$ ]]
}

# в”Ђв”Ђ Helper: classify health в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
classify() {
  CODE=$1
  TIME=$2
  API_OK=$3
  STATUS_IND=$4

  if [[ "$CODE" == "000" ]]; then
    echo -e "${RED}DOWN${NC}"
  elif [[ "$API_OK" == "вњ–" ]]; then
    echo -e "${RED}BROKEN${NC}"
  elif [[ "$STATUS_IND" =~ ^(major|critical)$ ]]; then
    echo -e "${RED}BROKEN${NC}"
  elif ! is_normal_http "$CODE"; then
    echo -e "${YELLOW}DEGRADED${NC}"
  elif awk "BEGIN {exit !($TIME > 1.5)}"; then
    echo -e "${YELLOW}DEGRADED${NC}"
  elif [[ "$STATUS_IND" == "minor" ]]; then
    echo -e "${YELLOW}DEGRADED${NC}"
  else
    echo -e "${GREEN}UP${NC}"
  fi
}

impact_text() {
  CODE=$1
  TIME=$2
  API_OK=$3
  STATUS_IND=$4
  ISSUES=$5

  if [[ "$CODE" == "000" ]]; then
    echo "No API response"
  elif [[ "$API_OK" == "вњ–" ]]; then
    echo "API endpoint behavior looks broken"
  elif [[ "$STATUS_IND" =~ ^(major|critical)$ ]]; then
    echo "Provider reports major service disruption"
  elif ! is_normal_http "$CODE"; then
    echo "Probe result was unusual, but service may still work"
  elif awk "BEGIN {exit !($TIME > 1.5)}"; then
    echo "Responses are slower than expected"
  elif [[ "$STATUS_IND" == "minor" && "$ISSUES" != "None" ]]; then
    echo "Partial service disruption reported"
  elif [[ "$STATUS_IND" == "minor" ]]; then
    echo "Provider reports minor service issues"
  else
    echo "No obvious service impact detected"
  fi
}

# в”Ђв”Ђ OpenAI в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
OPENAI_HTTP=$(curl -s -o /dev/null -w "%{http_code}" https://api.openai.com)
OPENAI_TIME=$(curl -o /dev/null -s -w "%{time_total}" https://api.openai.com)
OPENAI_API=$(curl -s https://api.openai.com/v1/models | jq -e '.error.type' >/dev/null && echo "вњ”" || echo "вњ–")
OPENAI_STATUS_DESC=$(curl -s https://status.openai.com/api/v2/summary.json | jq -r '.status.description')
OPENAI_STATUS_IND=$(curl -s https://status.openai.com/api/v2/summary.json | jq -r '.status.indicator')
OPENAI_ISSUES=$(curl -s https://status.openai.com/api/v2/summary.json | \
jq -r '.components[] | select(.status!="operational") | .name' | \
tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
OPENAI_ISSUES=${OPENAI_ISSUES:-None}
OPENAI_STATUS=$(color_status "$OPENAI_STATUS_IND" "$OPENAI_STATUS_DESC")
OPENAI_HTTP_LABEL=$(format_http "$OPENAI_HTTP")
OPENAI_HEALTH=$(classify "$OPENAI_HTTP" "$OPENAI_TIME" "$OPENAI_API" "$OPENAI_STATUS_IND")
OPENAI_IMPACT=$(impact_text "$OPENAI_HTTP" "$OPENAI_TIME" "$OPENAI_API" "$OPENAI_STATUS_IND" "$OPENAI_ISSUES")

# в”Ђв”Ђ Claude в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CLAUDE_HTTP=$(curl -s -o /dev/null -w "%{http_code}" https://api.anthropic.com)
CLAUDE_TIME=$(curl -o /dev/null -s -w "%{time_total}" https://api.anthropic.com)
CLAUDE_API=$(curl -s https://api.anthropic.com/v1/models | jq -e '.error.type' >/dev/null && echo "вњ”" || echo "вњ–")
CLAUDE_STATUS_DESC=$(curl -sL https://status.anthropic.com/api/v2/summary.json | jq -r '.status.description')
CLAUDE_STATUS_IND=$(curl -sL https://status.anthropic.com/api/v2/summary.json | jq -r '.status.indicator')
CLAUDE_ISSUES=$(curl -sL https://status.anthropic.com/api/v2/summary.json | \
jq -r '.components[] | select(.status!="operational") | .name' | \
tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')
CLAUDE_ISSUES=${CLAUDE_ISSUES:-None}
CLAUDE_STATUS=$(color_status "$CLAUDE_STATUS_IND" "$CLAUDE_STATUS_DESC")
CLAUDE_HTTP_LABEL=$(format_http "$CLAUDE_HTTP")
CLAUDE_HEALTH=$(classify "$CLAUDE_HTTP" "$CLAUDE_TIME" "$CLAUDE_API" "$CLAUDE_STATUS_IND")
CLAUDE_IMPACT=$(impact_text "$CLAUDE_HTTP" "$CLAUDE_TIME" "$CLAUDE_API" "$CLAUDE_STATUS_IND" "$CLAUDE_ISSUES")


# в”Ђв”Ђ Output в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "=== AI HEALTH CHECK ==="
echo "$(date)"
echo ""

printf "%-8s %b | %ss | HTTP:%s | API:%s | Status:%s | Impact:%s | Issues:%s\n" \
  "OpenAI" "$OPENAI_HEALTH" "$OPENAI_TIME" "$OPENAI_HTTP_LABEL" "$OPENAI_API" "$OPENAI_STATUS" "$OPENAI_IMPACT" "$OPENAI_ISSUES"

printf "%-8s %b | %ss | HTTP:%s | API:%s | Status:%s | Impact:%s | Issues:%s\n" \
  "Claude" "$CLAUDE_HEALTH" "$CLAUDE_TIME" "$CLAUDE_HTTP_LABEL" "$CLAUDE_API" "$CLAUDE_STATUS" "$CLAUDE_IMPACT" "$CLAUDE_ISSUES"
